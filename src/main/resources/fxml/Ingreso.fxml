<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.controladores.IngresoController"
            prefWidth="1000" prefHeight="680"
            style="-fx-background-color: #0a0f1e;">
    <left>
        <VBox styleClass="sidebar" spacing="0">
            <VBox styleClass="sidebar-header" spacing="6">
                <Label text="🔒" style="-fx-font-size: 26px;"/>
                <Label text="Control de Seguridad"
                       style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Label fx:id="lblUsuario" text=""
                       style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 11px;"/>
            </VBox>
            <Label text="ACCESOS" styleClass="sidebar-seccion"/>
            <Button text="  🚪  Ingreso por Puerta" styleClass="btn-menu" onAction="#irIngresoPuerta"/>
            <Button text="  🚫  Ver Restricciones"  styleClass="btn-menu" onAction="#irRestricciones"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="  🚪  Cerrar Sesión"
                    styleClass="btn-menu" style="-fx-text-fill: rgba(255,100,100,0.8);"
                    onAction="#cerrarSesion"/>
            <Region minHeight="10"/>
        </VBox>
    </left>
    <center>
        <VBox>
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="15">
                <Label fx:id="lblTitulo" text="Control de Ingreso"
                       style="-fx-text-fill: #e8edf5; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            </HBox>
            <StackPane fx:id="contenedor" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #0a0f1e; -fx-padding: 25;"/>
        </VBox>
    </center>
</BorderPane>
