<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="app.controladores.AuditoriaController"
      spacing="15" style="-fx-padding: 20; -fx-background-color: #0d1224;">

    <HBox spacing="15">
        <VBox styleClass="tarjeta-stat" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4"
              style="-fx-background-color:#111827;-fx-background-radius:8;-fx-padding:16;">
            <Label text="TOTAL ACCIONES" style="-fx-text-fill:rgba(255,255,255,0.5);-fx-font-size:10px;"/>
            <Label fx:id="lblResTotal" text="0" style="-fx-text-fill:#4fc3f7;-fx-font-size:24px;-fx-font-weight:bold;"/>
        </VBox>
        <VBox styleClass="tarjeta-stat" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4"
              style="-fx-background-color:#111827;-fx-background-radius:8;-fx-padding:16;">
            <Label text="EXITOSAS" style="-fx-text-fill:rgba(255,255,255,0.5);-fx-font-size:10px;"/>
            <Label fx:id="lblResExitosas" text="0" style="-fx-text-fill:#27ae60;-fx-font-size:24px;-fx-font-weight:bold;"/>
        </VBox>
        <VBox styleClass="tarjeta-stat" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4"
              style="-fx-background-color:#111827;-fx-background-radius:8;-fx-padding:16;">
            <Label text="FALLIDAS" style="-fx-text-fill:rgba(255,255,255,0.5);-fx-font-size:10px;"/>
            <Label fx:id="lblResFallidas" text="0" style="-fx-text-fill:#e74c3c;-fx-font-size:24px;-fx-font-weight:bold;"/>
        </VBox>
        <VBox styleClass="tarjeta-stat" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4"
              style="-fx-background-color:#111827;-fx-background-radius:8;-fx-padding:16;">
            <Label text="ALERTAS ACTIVAS" style="-fx-text-fill:rgba(255,255,255,0.5);-fx-font-size:10px;"/>
            <Label fx:id="lblResAlertas" text="0" style="-fx-text-fill:#f39c12;-fx-font-size:24px;-fx-font-weight:bold;"/>
        </VBox>
    </HBox>

    <TabPane fx:id="tabPane" VBox.vgrow="ALWAYS">
        <Tab text="📋  Registro de Acciones" closable="false">
            <VBox spacing="10" style="-fx-padding:15;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="txtFiltro" promptText="Buscar..." styleClass="campo-texto" prefWidth="200"/>
                    <ComboBox fx:id="cmbModulo" promptText="Módulo" prefWidth="140"/>
                    <ComboBox fx:id="cmbResultado" promptText="Resultado" prefWidth="130"/>
                    <Button text="🔄  Refrescar" styleClass="btn-secundario" onAction="#onRefrescarAcciones"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblTotalAcciones" text="0 registros" style="-fx-text-fill:rgba(255,255,255,0.5);-fx-font-size:11px;"/>
                </HBox>
                <TableView fx:id="tablaAcciones" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colFechaA"     text="Fecha/Hora"  prefWidth="140"/>
                        <TableColumn fx:id="colUsuarioA"   text="Usuario"     prefWidth="110"/>
                        <TableColumn fx:id="colRolA"       text="Rol"         prefWidth="100"/>
                        <TableColumn fx:id="colModuloA"    text="Módulo"      prefWidth="100"/>
                        <TableColumn fx:id="colAccionA"    text="Acción"      prefWidth="140"/>
                        <TableColumn fx:id="colDescA"      text="Descripción" prefWidth="160"/>
                        <TableColumn fx:id="colResultadoA" text="Resultado"   prefWidth="85"/>
                        <TableColumn fx:id="colIPA"        text="IP"          prefWidth="110"/>
                    </columns>
                    <placeholder><Label text="Sin registros" style="-fx-text-fill:rgba(255,255,255,0.3);"/></placeholder>
                </TableView>
            </VBox>
        </Tab>
        <Tab text="🔐  Intentos de Login" closable="false">
            <VBox spacing="10" style="-fx-padding:15;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="🔄  Refrescar" styleClass="btn-secundario" onAction="#onRefrescarIntentos"/>
                    <Button text="🔓  Desbloquear Usuario" styleClass="btn-secundario" onAction="#onDesbloquear"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblTotalIntentos" text="0 intentos" style="-fx-text-fill:rgba(255,255,255,0.5);-fx-font-size:11px;"/>
                    <Label fx:id="lblFallidosHoy" text="0 fallidos hoy" style="-fx-text-fill:#e74c3c;-fx-font-size:11px;"/>
                </HBox>
                <TableView fx:id="tablaIntentos" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colFechaI"     text="Fecha/Hora" prefWidth="140"/>
                        <TableColumn fx:id="colUsuarioI"   text="Usuario"    prefWidth="130"/>
                        <TableColumn fx:id="colIPI"        text="IP"         prefWidth="120"/>
                        <TableColumn fx:id="colMetodoI"    text="Método"     prefWidth="100"/>
                        <TableColumn fx:id="colResultadoI" text="Resultado"  prefWidth="90"/>
                        <TableColumn                        text="Bloqueado"  prefWidth="90"/>
                    </columns>
                    <placeholder><Label text="Sin intentos registrados" style="-fx-text-fill:rgba(255,255,255,0.3);"/></placeholder>
                </TableView>
            </VBox>
        </Tab>
        <Tab text="⚠  Alertas del Sistema" closable="false">
            <VBox spacing="10" style="-fx-padding:15;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <CheckBox fx:id="chkSoloActivas" text="Solo activas" style="-fx-text-fill:rgba(255,255,255,0.7);"/>
                    <Button text="🔄  Refrescar" styleClass="btn-secundario" onAction="#onRefrescarAlertas"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblAlertasActivas" text="0 activas" style="-fx-text-fill:#f39c12;-fx-font-size:11px;"/>
                </HBox>
                <TableView fx:id="tablaAlertas" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colFechaAl"  text="Fecha/Hora"  prefWidth="140"/>
                        <TableColumn fx:id="colTipoAl"   text="Tipo"        prefWidth="120"/>
                        <TableColumn fx:id="colDescAl"   text="Descripción" prefWidth="220"/>
                        <TableColumn fx:id="colIPAl"     text="IP"          prefWidth="100"/>
                        <TableColumn fx:id="colEstadoAl" text="Estado"      prefWidth="90"/>
                        <TableColumn fx:id="colAccionAl" text="Acción"      prefWidth="100"/>
                    </columns>
                    <placeholder><Label text="Sin alertas" style="-fx-text-fill:rgba(255,255,255,0.3);"/></placeholder>
                </TableView>
            </VBox>
        </Tab>
    </TabPane>
</VBox>