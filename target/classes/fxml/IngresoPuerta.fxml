<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<HBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="app.controladores.IngresoPuertaController"
      spacing="20"
      style="-fx-padding: 5;">

    <!-- ═══════════════════════════════════════════
         PANEL CÁMARA — Vista en vivo
    ═══════════════════════════════════════════ -->
    <VBox spacing="15" minWidth="480" maxWidth="480">

        <!-- Feed cámara -->
        <VBox styleClass="card" spacing="10">
            <Label fx:id="lblCamaraUtilizar"
                   text="📷  Cámara a utilizar:"
                   style="-fx-text-fill: #8a9bbf; -fx-font-size: 11px;"/>
            <ComboBox fx:id="cmbCamara"
                      promptText="Seleccionando cámaras..."
                      maxWidth="1.7976931348623157E308"
                      style="-fx-background-color:#0d1829;-fx-text-fill:#e8edf5;
                 -fx-border-color:#1e2d47;-fx-border-radius:6;
                 -fx-background-radius:6;"/>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Circle radius="6" fill="#27ae60" fx:id="indicadorEstado"/>
                <Label fx:id="lblEstadoCamara"
                       text="Cámara inactiva"
                       style="-fx-text-fill: #8a9bbf; -fx-font-size: 12px;"/>
            </HBox>

            <StackPane fx:id="stackCamara"
                       minWidth="440" minHeight="330" maxWidth="440" maxHeight="330"
                       styleClass="camara-preview">
                <ImageView fx:id="imgCamara"
                           fitWidth="438" fitHeight="328"
                           preserveRatio="true"/>
                <VBox alignment="CENTER" spacing="8" fx:id="panelSinCamara">
                    <Label text="📷" style="-fx-font-size: 48px;"/>
                    <Label text="Activar cámara para iniciar reconocimiento"
                           style="-fx-text-fill: #4a5a78; -fx-font-size: 12px;"
                           wrapText="true" textAlignment="CENTER" maxWidth="200"/>
                </VBox>
            </StackPane>

            <HBox spacing="10">
                <Button fx:id="btnIniciarCamara"
                        text="▶ Iniciar Reconocimiento"
                        styleClass="btn-exito"
                        HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"
                        onAction="#iniciarReconocimiento"/>
                <Button fx:id="btnDetenerCamara"
                        text="⏹ Detener"
                        styleClass="btn-peligro"
                        disable="true"
                        onAction="#detenerReconocimiento"/>
            </HBox>
        </VBox>

        <!-- Selector de puerta -->
        <VBox styleClass="card" spacing="10">
            <Label text="📍 Configuración de Puerta"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #e8edf5;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="INSTALACIÓN" styleClass="etiqueta-campo"/>
                    <ComboBox fx:id="cmbInstalacion"
                              promptText="Seleccionar..."
                              maxWidth="1.7976931348623157E308"
                              onAction="#cargarPuertas"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="PUERTA" styleClass="etiqueta-campo"/>
                    <ComboBox fx:id="cmbPuerta"
                              promptText="Seleccionar puerta..."
                              maxWidth="1.7976931348623157E308"/>
                </VBox>
            </HBox>
        </VBox>

    </VBox>

    <!-- ═══════════════════════════════════════════
         PANEL RESULTADO — Persona identificada
    ═══════════════════════════════════════════ -->
    <VBox spacing="15" HBox.hgrow="ALWAYS">

        <!-- Resultado del reconocimiento -->
        <VBox fx:id="cardResultado" styleClass="card" spacing="15"
              alignment="CENTER" minHeight="280">

            <!-- Estado: esperando -->
            <VBox fx:id="panelEsperando" alignment="CENTER" spacing="10">
                <Label text="🔍" style="-fx-font-size: 52px;"/>
                <Label text="Esperando persona..."
                       style="-fx-text-fill: #4a5a78; -fx-font-size: 14px;"/>
                <Label text="Active la cámara para iniciar el reconocimiento facial"
                       style="-fx-text-fill: #2a3a5a; -fx-font-size: 11px;"
                       wrapText="true" textAlignment="CENTER" maxWidth="250"/>
            </VBox>

            <!-- Estado: reconociendo -->
            <VBox fx:id="panelReconociendo" alignment="CENTER" spacing="10"
                  visible="false" managed="false">
                <ProgressIndicator style="-fx-progress-color: #4080ff;" maxWidth="50"/>
                <Label text="Analizando rostro..."
                       style="-fx-text-fill: #4080ff; -fx-font-size: 14px;"/>
            </VBox>

            <!-- Estado: identificado ✅ -->
            <VBox fx:id="panelIdentificado" alignment="CENTER" spacing="12"
                  visible="false" managed="false">
                <Label text="✅ ACCESO PERMITIDO"
                       style="-fx-text-fill: #27ae60; -fx-font-size: 16px; -fx-font-weight: bold;"/>

                <ImageView fx:id="imgPersonaId"
                           fitWidth="100" fitHeight="100"
                           preserveRatio="true"
                           style="-fx-border-radius: 50; -fx-effect: dropshadow(gaussian, rgba(39,174,96,0.5), 15, 0, 0, 0);"/>

                <VBox alignment="CENTER" spacing="4">
                    <Label fx:id="lblNombreId"
                           text=""
                           style="-fx-text-fill: #e8edf5; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label fx:id="lblTipoId"
                           text=""
                           style="-fx-text-fill: #8a9bbf; -fx-font-size: 12px;"/>
                    <Label fx:id="lblCarreraId"
                           text=""
                           style="-fx-text-fill: #4a5a78; -fx-font-size: 11px;"/>
                </VBox>

                <Label fx:id="lblHoraIngreso"
                       text=""
                       style="-fx-text-fill: #27ae60; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Estado: restringido ❌ -->
            <VBox fx:id="panelRestringido" alignment="CENTER" spacing="12"
                  visible="false" managed="false">
                <Label text="🚫 ACCESO DENEGADO"
                       style="-fx-text-fill: #e74c3c; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label text="⚠"
                       style="-fx-font-size: 48px;"/>
                <Label fx:id="lblNombreRestringido"
                       text=""
                       style="-fx-text-fill: #e8edf5; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label text="Persona con restricción de acceso activa"
                       style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;"/>
                <Label fx:id="lblMotivoRestriccion"
                       text=""
                       style="-fx-text-fill: #8a9bbf; -fx-font-size: 11px;"
                       wrapText="true" textAlignment="CENTER" maxWidth="250"/>
            </VBox>

            <!-- Estado: no reconocido -->
            <VBox fx:id="panelNoReconocido" alignment="CENTER" spacing="10"
                  visible="false" managed="false">
                <Label text="❓"
                       style="-fx-font-size: 48px;"/>
                <Label text="PERSONA NO IDENTIFICADA"
                       style="-fx-text-fill: #f39c12; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Label text="El rostro no coincide con ningún registro"
                       style="-fx-text-fill: #4a5a78; -fx-font-size: 11px;"/>
            </VBox>
        </VBox>

        <!-- Registro de ingresos del día -->
        <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <Label text="📋 Ingresos de Hoy"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #e8edf5;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblContadorIngresos"
                       text="0 registros"
                       style="-fx-text-fill: #4a5a78; -fx-font-size: 11px;"/>
            </HBox>

            <TableView fx:id="tablaIngresos" styleClass="table-view" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNombreIngreso" text="Nombre" prefWidth="150"/>
                    <TableColumn fx:id="colTipoIngreso"   text="Tipo"   prefWidth="90"/>
                    <TableColumn fx:id="colHoraIngreso"   text="Hora"   prefWidth="80"/>
                </columns>
                <placeholder>
                    <Label text="Sin ingresos registrados hoy"
                           style="-fx-text-fill: #4a5a78;"/>
                </placeholder>
            </TableView>
        </VBox>

    </VBox>

</HBox>
