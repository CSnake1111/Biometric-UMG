<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.controladores.DashboardController"
            prefWidth="1280" prefHeight="800"
            style="-fx-background-color: #0a0f1e;"
            stylesheets="@../css/estilos.css">

    <!-- ═══════════════════════════════════════════
         SIDEBAR IZQUIERDO
    ═══════════════════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar" spacing="0" maxWidth="250" minWidth="250">

            <!-- Header: logo + usuario -->
            <VBox styleClass="sidebar-header" spacing="6">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <ImageView fx:id="imgLogoSidebar" fitWidth="38" fitHeight="38" preserveRatio="true"/>
                    <VBox spacing="2">
                        <Label text="BiometricUMG" styleClass="sidebar-titulo"/>
                        <Label text="2.0 — 2026" style="-fx-text-fill:rgba(255,255,255,0.4);-fx-font-size:9px;"/>
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding:8 0 0 0;">
                    <Circle radius="5" fill="#27ae60"/>
                    <VBox spacing="1">
                        <Label fx:id="lblUsuarioSidebar" text="" styleClass="sidebar-titulo"
                               style="-fx-font-size:13px;"/>
                        <Label fx:id="lblRolBadge" text="" styleClass="badge-rol"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Menú scrolleable -->
            <ScrollPane VBox.vgrow="ALWAYS" hbarPolicy="NEVER"
                        styleClass="sidebar-scroll" fitToWidth="true">
                <VBox spacing="2" style="-fx-padding:8 8 8 8;">

                    <!-- GENERAL -->
                    <Label text="GENERAL" styleClass="sidebar-seccion"/>
                    <Button fx:id="btnDashboard" text="  🏠  Dashboard"
                            styleClass="btn-menu" maxWidth="1.7976931348623157E308"
                            onAction="#mostrarDashboard"/>

                    <!-- PERSONAS -->
                    <Label text="PERSONAS" styleClass="sidebar-seccion"/>
                    <Button fx:id="btnRegistro" text="  👤  Registro de Personas"
                            styleClass="btn-menu" maxWidth="1.7976931348623157E308"
                            onAction="#mostrarRegistroPersonas"/>
                    <Button fx:id="btnListaPersonas" text="  📋  Personas Registradas"
                            styleClass="btn-menu" maxWidth="1.7976931348623157E308"
                            onAction="#mostrarListaPersonas"/>


                    <!-- CONTROL -->
                    <Label text="CONTROL DE INGRESO" styleClass="sidebar-seccion"/>
                    <Button fx:id="btnPuerta" text="  🚪  Ingreso por Puerta"
                            styleClass="btn-menu" maxWidth="1.7976931348623157E308"
                            onAction="#mostrarIngresoPuerta"/>
                    <Button fx:id="btnSalon" text="  🏫  Ingreso por Salón"
                            styleClass="btn-menu" maxWidth="1.7976931348623157E308"
                            onAction="#mostrarIngresoSalon"/>
                    <Button fx:id="btnRestricciones" text="  🚫  Restricciones"
                            styleClass="btn-menu" maxWidth="1.7976931348623157E308"
                            onAction="#mostrarRestricciones"/>
                    <Button fx:id="btnIntrusos" text="  ⚠  Intrusos"
                            styleClass="btn-menu" maxWidth="1.7976931348623157E308"
                            onAction="#mostrarIntrusos"/>

                    <!-- ACADÉMICO -->
                    <Label text="ACADÉMICO" styleClass="sidebar-seccion"/>
                    <Button fx:id="btnCursos" text="  📚  Gestión de Cursos"
                            styleClass="btn-menu" maxWidth="1.7976931348623157E308"
                            onAction="#mostrarGestionCursos"/>
                    <Button fx:id="btnArbol" text="  🌳  Árbol de Asistencias"
                            styleClass="btn-menu" maxWidth="1.7976931348623157E308"
                            onAction="#mostrarArbolAsistencias"/>
                    <Button fx:id="btnEntrenamiento" text="  🧠  Entrenamiento Facial"
                            styleClass="btn-menu" maxWidth="1.7976931348623157E308"
                            onAction="#mostrarEntrenamiento"/>

                    <!-- REPORTES -->
                    <Label text="REPORTES" styleClass="sidebar-seccion"/>
                    <Button fx:id="btnRepPuerta" text="  📊  Reportes — Puerta"
                            styleClass="btn-menu" maxWidth="1.7976931348623157E308"
                            onAction="#mostrarReportesPuerta"/>
                    <Button fx:id="btnRepSalon" text="  📊  Reportes — Salón"
                            styleClass="btn-menu" maxWidth="1.7976931348623157E308"
                            onAction="#mostrarReportesSalon"/>
                    <Button fx:id="btnAnalitica" text="  📈  Analítica Inteligente"
                            styleClass="btn-menu" maxWidth="1.7976931348623157E308"
                            onAction="#mostrarAnalitica"/>

                    <!-- ADMIN -->
                    <Label text="ADMINISTRACIÓN" styleClass="sidebar-seccion"/>
                    <Button fx:id="btnUsuarios" text="  👥  Gestión de Usuarios"
                            styleClass="btn-menu" maxWidth="1.7976931348623157E308"
                            onAction="#mostrarGestionUsuarios"/>
                    <Button fx:id="btnCambiarPass" text="  🔑  Cambiar Contraseña"
                            styleClass="btn-menu" maxWidth="1.7976931348623157E308"
                            onAction="#mostrarCambiarPass"/>
                    <!-- Badge de alertas en el botón de auditoría -->
                    <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308">
                        <Button fx:id="btnAuditoria" text="  🔍  Auditoría"
                                styleClass="btn-menu" HBox.hgrow="ALWAYS"
                                onAction="#mostrarAuditoria"/>
                        <Label fx:id="lblAlertasBadge" text="" styleClass="sidebar-badge"
                               visible="false" managed="false" style="-fx-padding:2 6;"/>
                    </HBox>

                </VBox>
            </ScrollPane>

            <!-- Footer: cerrar sesión -->
            <VBox spacing="4" style="-fx-padding:8 8 10 8;">
                <Region minHeight="1" maxHeight="1"
                        style="-fx-background-color:rgba(255,255,255,0.1);"/>
                <Button fx:id="btnCerrar" text="  🚪  Cerrar Sesión"
                        styleClass="btn-menu"
                        style="-fx-text-fill:rgba(255,100,100,0.85);"
                        maxWidth="1.7976931348623157E308"
                        onAction="#cerrarSesion"/>
            </VBox>
        </VBox>
    </left>

    <!-- ═══════════════════════════════════════════
         CONTENIDO PRINCIPAL
    ═══════════════════════════════════════════ -->
    <center>
        <VBox>

            <!-- Topbar -->
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="15">
                <Label fx:id="lblTituloPantalla" text="Dashboard"
                       style="-fx-text-fill:#e8edf5;-fx-font-size:18px;-fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblEstadoBD" text="● BD"
                       style="-fx-font-size:11px;-fx-text-fill:#27ae60;"/>
                <Label fx:id="lblFechaHora" text="00:00:00"
                       style="-fx-text-fill:#4a5a78;-fx-font-size:12px;"/>
            </HBox>

            <!-- Área dinámica -->
            <StackPane fx:id="contenedorPrincipal" VBox.vgrow="ALWAYS"
                       style="-fx-background-color:#0a0f1e;">

                <!-- Panel de inicio (se oculta al navegar) -->
                <VBox fx:id="panelInicio" spacing="20"
                      style="-fx-padding:25 30 25 30;">

                    <!-- Bienvenida -->
                    <VBox spacing="4">
                        <Label fx:id="lblBienvenida" text="Bienvenido"
                               style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#e8edf5;"/>
                        <Label fx:id="lblFechaBienvenida" text=""
                               style="-fx-text-fill:#4a5a78;-fx-font-size:13px;"/>
                    </VBox>

                    <!-- Tarjetas de estadísticas — fila 1 -->
                    <HBox spacing="15">
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8"
                              onMouseClicked="#mostrarListaPersonas"
                              style="-fx-cursor:hand;">
                            <Label text="👥" styleClass="stat-icono"/>
                            <Label fx:id="statPersonas" text="0" styleClass="stat-numero"/>
                            <Label text="Personas" styleClass="stat-titulo"/>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8"
                              onMouseClicked="#mostrarIngresoPuerta"
                              style="-fx-cursor:hand;">
                            <Label text="🚪" styleClass="stat-icono"/>
                            <Label fx:id="statIngresosHoy" text="0" styleClass="stat-numero"/>
                            <Label text="Ingresos Hoy" styleClass="stat-titulo"/>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8"
                              onMouseClicked="#mostrarArbolAsistencias"
                              style="-fx-cursor:hand;">
                            <Label text="✅" styleClass="stat-icono"/>
                            <Label fx:id="statAsistencias" text="0" styleClass="stat-numero"/>
                            <Label text="Asistencias" styleClass="stat-titulo"/>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8"
                              onMouseClicked="#mostrarRestricciones"
                              style="-fx-cursor:hand;">
                            <Label text="🚫" styleClass="stat-icono"/>
                            <Label fx:id="statRestricciones" text="0" styleClass="stat-numero"/>
                            <Label text="Restricciones" styleClass="stat-titulo"/>
                        </VBox>
                    </HBox>

                    <!-- Tarjetas fila 2 -->
                    <HBox spacing="15">
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8"
                              onMouseClicked="#mostrarIntrusos"
                              style="-fx-cursor:hand;">
                            <Label text="⚠" styleClass="stat-icono"
                                   style="-fx-text-fill:#e74c3c;"/>
                            <Label fx:id="statIntrusos" text="0" styleClass="stat-numero"
                                   style="-fx-text-fill:#e74c3c;"/>
                            <Label text="Intrusos Hoy" styleClass="stat-titulo"/>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8"
                              onMouseClicked="#mostrarArbolAsistencias"
                              style="-fx-cursor:hand;">
                            <Label text="📈" styleClass="stat-icono"
                                   style="-fx-text-fill:#27ae60;"/>
                            <Label fx:id="statPctAsistencia" text="0%" styleClass="stat-numero"
                                   style="-fx-text-fill:#27ae60;"/>
                            <Label text=" % Asistencia Hoy" styleClass="stat-titulo"/>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8"
                              onMouseClicked="#mostrarAnalitica"
                              style="-fx-cursor:hand;">
                            <Label text="🔴" styleClass="stat-icono"
                                   style="-fx-text-fill:#f39c12;"/>
                            <Label fx:id="statEnRiesgo" text="0" styleClass="stat-numero"
                                   style="-fx-text-fill:#f39c12;"/>
                            <Label text="En Riesgo" styleClass="stat-titulo"/>
                        </VBox>
                    </HBox>

                    <!-- Tabla últimos ingresos -->
                    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="10">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="📋 Últimos Ingresos"
                                   style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#e8edf5;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="🔄" styleClass="btn-icono"
                                    onAction="#mostrarDashboard"
                                    style="-fx-padding:5 10;"/>
                        </HBox>
                        <TableView fx:id="tablaUltimosIngresos" styleClass="table-view"
                                   VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colNombre"    text="Nombre"    prefWidth="220"/>
                                <TableColumn fx:id="colTipo"      text="Tipo"      prefWidth="120"/>
                                <TableColumn fx:id="colUbicacion" text="Ubicación" prefWidth="160"/>
                                <TableColumn fx:id="colFechaHora" text="Fecha/Hora" prefWidth="160"/>
                            </columns>
                            <placeholder>
                                <Label text="Sin ingresos recientes"
                                       style="-fx-text-fill:#4a5a78;"/>
                            </placeholder>
                        </TableView>
                    </VBox>

                </VBox>
            </StackPane>
        </VBox>
    </center>

</BorderPane>
