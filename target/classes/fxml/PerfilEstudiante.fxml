<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.controladores.PerfilEstudianteController"
            prefWidth="980" prefHeight="720"
            style="-fx-background-color:#0a0f1e;"
            stylesheets="@../css/estilos.css">

    <!-- ══ SIDEBAR ══════════════════════════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar" spacing="0" maxWidth="230" minWidth="230">
            <VBox styleClass="sidebar-header" spacing="6">
                <Label text="🎓" style="-fx-font-size:28px;"/>
                <Label text="Mi Portal" styleClass="sidebar-titulo"/>
            </VBox>

            <Label text="ACCIONES" styleClass="sidebar-seccion"/>
            <Button text="  📄  Ver mi Carnet" styleClass="btn-menu"
                    maxWidth="1.7976931348623157E308" onAction="#verCarnet"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Button text="  🚪  Cerrar Sesión" styleClass="btn-menu"
                    style="-fx-text-fill:rgba(255,100,100,0.8);"
                    maxWidth="1.7976931348623157E308" onAction="#cerrarSesion"/>
            <Region minHeight="8"/>
        </VBox>
    </left>

    <!-- ══ CONTENIDO PRINCIPAL ══════════════════════════════════════ -->
    <center>
        <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color:transparent;-fx-background:transparent;">
            <VBox spacing="18" style="-fx-padding:24;">

                <!-- ── HEADER PERFIL ─────────────────────────────── -->
                <HBox fx:id="anchorResumen" spacing="22" alignment="CENTER_LEFT"
                      style="-fx-background-color:#111827;-fx-background-radius:14;-fx-padding:22;">

                    <ImageView fx:id="imgFoto" fitWidth="90" fitHeight="90" preserveRatio="false"
                               style="-fx-effect:dropshadow(gaussian,rgba(79,195,247,0.35),14,0,0,0);"/>

                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblNombre" text=""
                               style="-fx-text-fill:#e8edf5;-fx-font-size:21px;-fx-font-weight:bold;"/>
                        <Label fx:id="lblCarrera" text=""
                               style="-fx-text-fill:#4fc3f7;-fx-font-size:12px;"/>

                        <!-- chips: sección / estado / alerta -->
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label fx:id="lblChipSeccion" text=""
                                   style="-fx-background-color:#1a3a5c;-fx-text-fill:#4fc3f7;
                                          -fx-background-radius:20;-fx-padding:3 10;-fx-font-size:10px;"/>
                            <Label text="Activa"
                                   style="-fx-background-color:#1a3a1a;-fx-text-fill:#27ae60;
                                          -fx-background-radius:20;-fx-padding:3 10;-fx-font-size:10px;"/>
                            <Label fx:id="lblChipAlerta" text=""
                                   style="-fx-background-color:#3a2a10;-fx-text-fill:#f39c12;
                                          -fx-background-radius:20;-fx-padding:3 10;-fx-font-size:10px;"
                                   visible="false" managed="false"/>
                        </HBox>

                        <HBox spacing="24" style="-fx-padding:6 0 0 0;">
                            <VBox spacing="2">
                                <Label text="Carné"
                                       style="-fx-text-fill:rgba(255,255,255,0.38);-fx-font-size:9px;"/>
                                <Label fx:id="lblCarne" text=""
                                       style="-fx-text-fill:rgba(255,255,255,0.7);-fx-font-size:11px;"/>
                            </VBox>
                            <VBox spacing="2">
                                <Label text="Sección"
                                       style="-fx-text-fill:rgba(255,255,255,0.38);-fx-font-size:9px;"/>
                                <Label fx:id="lblSeccion" text=""
                                       style="-fx-text-fill:rgba(255,255,255,0.7);-fx-font-size:11px;"/>
                            </VBox>
                            <VBox spacing="2">
                                <Label text="Correo"
                                       style="-fx-text-fill:rgba(255,255,255,0.38);-fx-font-size:9px;"/>
                                <Label fx:id="lblCorreo" text=""
                                       style="-fx-text-fill:rgba(255,255,255,0.7);-fx-font-size:11px;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <ImageView fx:id="imgQR" fitWidth="90" fitHeight="90" preserveRatio="true"/>
                </HBox>

                <!-- ── ESTADÍSTICAS (4 tarjetas) ──────────────────── -->
                <HBox spacing="12">
                    <!-- Asistencia global -->
                    <VBox HBox.hgrow="ALWAYS" spacing="4" alignment="CENTER"
                          style="-fx-background-color:#111827;-fx-background-radius:10;-fx-padding:16;">
                        <Label text="Asistencia global"
                               style="-fx-text-fill:rgba(255,255,255,0.4);-fx-font-size:10px;"/>
                        <Label fx:id="lblPctGlobal" text="—%"
                               style="-fx-text-fill:#27ae60;-fx-font-size:22px;-fx-font-weight:bold;"/>
                    </VBox>
                    <!-- Clases asistidas -->
                    <VBox HBox.hgrow="ALWAYS" spacing="4" alignment="CENTER"
                          style="-fx-background-color:#111827;-fx-background-radius:10;-fx-padding:16;">
                        <Label text="Clases asistidas"
                               style="-fx-text-fill:rgba(255,255,255,0.4);-fx-font-size:10px;"/>
                        <Label fx:id="lblClasesAsistidas" text="—"
                               style="-fx-text-fill:#e8edf5;-fx-font-size:22px;-fx-font-weight:bold;"/>
                    </VBox>
                    <!-- Tardanzas -->
                    <VBox HBox.hgrow="ALWAYS" spacing="4" alignment="CENTER"
                          style="-fx-background-color:#111827;-fx-background-radius:10;-fx-padding:16;">
                        <Label text="Tardanzas"
                               style="-fx-text-fill:rgba(255,255,255,0.4);-fx-font-size:10px;"/>
                        <Label fx:id="lblTardanzas" text="—"
                               style="-fx-text-fill:#f39c12;-fx-font-size:22px;-fx-font-weight:bold;"/>
                    </VBox>
                    <!-- Ausencias -->
                    <VBox HBox.hgrow="ALWAYS" spacing="4" alignment="CENTER"
                          style="-fx-background-color:#111827;-fx-background-radius:10;-fx-padding:16;">
                        <Label text="Ausencias"
                               style="-fx-text-fill:rgba(255,255,255,0.4);-fx-font-size:10px;"/>
                        <Label fx:id="lblAusencias" text="—"
                               style="-fx-text-fill:#e74c3c;-fx-font-size:22px;-fx-font-weight:bold;"/>
                    </VBox>
                </HBox>

                <!-- ── CURSOS ACTUALES + ÚLTIMOS REGISTROS (2 col) ── -->
                <HBox fx:id="anchorCursos" spacing="14" alignment="TOP_LEFT">

                    <!-- Cursos actuales -->
                    <VBox HBox.hgrow="ALWAYS" spacing="10"
                          style="-fx-background-color:#111827;-fx-background-radius:12;-fx-padding:18;">
                        <Label text="📚  Cursos Actuales"
                               style="-fx-text-fill:#e8edf5;-fx-font-size:14px;-fx-font-weight:bold;"/>
                        <VBox fx:id="listaCursosActuales" spacing="8"/>
                        <Label fx:id="lblSinCursosActuales" text="Sin cursos inscritos actualmente."
                               style="-fx-text-fill:rgba(255,255,255,0.3);-fx-font-size:12px;"
                               visible="false" managed="false"/>
                    </VBox>

                    <!-- Últimos registros de asistencia -->
                    <VBox fx:id="anchorHistorial" minWidth="290" maxWidth="310" spacing="10"
                          style="-fx-background-color:#111827;-fx-background-radius:12;-fx-padding:18;">
                        <Label text="🕐  Últimos Registros"
                               style="-fx-text-fill:#e8edf5;-fx-font-size:14px;-fx-font-weight:bold;"/>
                        <VBox fx:id="listaUltimosRegistros" spacing="6"/>
                        <Label fx:id="lblSinRegistros" text="Sin registros recientes."
                               style="-fx-text-fill:rgba(255,255,255,0.3);-fx-font-size:12px;"
                               visible="false" managed="false"/>
                    </VBox>
                </HBox>

                <!-- ── HISTORIAL DE CURSOS ANTERIORES ─────────────── -->
                <VBox spacing="10"
                      style="-fx-background-color:#111827;-fx-background-radius:12;-fx-padding:18;">
                    <Label text="📁  Historial de Cursos"
                           style="-fx-text-fill:#e8edf5;-fx-font-size:14px;-fx-font-weight:bold;"/>
                    <VBox fx:id="listaCursosAnteriores" spacing="6"/>
                    <Label fx:id="lblSinCursosAnteriores" text="Sin historial de cursos."
                           style="-fx-text-fill:rgba(255,255,255,0.3);-fx-font-size:12px;"
                           visible="false" managed="false"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
