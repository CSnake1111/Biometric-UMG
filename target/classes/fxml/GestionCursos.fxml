<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="app.controladores.GestionCursosController"
      spacing="15" style="-fx-padding:20;-fx-background-color:#0d1224;">

    <Label text="📚  Gestión de Cursos"
           style="-fx-text-fill:#4fc3f7;-fx-font-size:18px;-fx-font-weight:bold;"/>

    <HBox spacing="20" VBox.vgrow="ALWAYS">

        <!-- Lista de cursos -->
        <VBox spacing="10" HBox.hgrow="ALWAYS"
              style="-fx-background-color:#111827;-fx-background-radius:12;-fx-padding:18;">
            <Label text="Cursos Registrados"
                   style="-fx-text-fill:#e8edf5;-fx-font-size:13px;-fx-font-weight:bold;"/>
            <TableView fx:id="tablaCursos" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNombreCurso" text="Curso"       prefWidth="160"/>
                    <TableColumn fx:id="colSeccion"     text="Sección"     prefWidth="70"/>
                    <TableColumn fx:id="colHorario"     text="Horario"     prefWidth="130"/>
                    <TableColumn fx:id="colCatedratico" text="Catedrático" prefWidth="140"/>
                    <TableColumn fx:id="colSalon"       text="Salón"       prefWidth="90"/>
                </columns>
                <placeholder>
                    <Label text="Sin cursos registrados"
                           style="-fx-text-fill:rgba(255,255,255,0.3);"/>
                </placeholder>
            </TableView>
            <HBox spacing="10">
                <Button text="🗑  Eliminar Curso"
                        style="-fx-background-color:rgba(231,76,60,0.15);-fx-border-color:rgba(231,76,60,0.4);-fx-border-radius:8;-fx-background-radius:8;-fx-text-fill:#e74c3c;-fx-font-size:12px;-fx-padding:7 14;-fx-cursor:hand;"
                        onAction="#eliminarCurso"/>
            </HBox>
        </VBox>

        <!-- Panel derecho: form + inscritos -->
        <VBox spacing="15" minWidth="360" maxWidth="380">

            <!-- Formulario nuevo/editar curso -->
            <VBox spacing="12"
                  style="-fx-background-color:#111827;-fx-background-radius:12;-fx-padding:18;">

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="lblTituloForm" text="Nuevo Curso"
                           style="-fx-text-fill:#e8edf5;-fx-font-size:13px;-fx-font-weight:bold;"
                           HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnCancelarEdicion" text="✕ Cancelar"
                            onAction="#cancelarEdicion"
                            visible="false" managed="false"
                            style="-fx-background-color:rgba(107,114,128,0.2);-fx-border-color:rgba(107,114,128,0.35);-fx-border-radius:7;-fx-background-radius:7;-fx-text-fill:#9ca3af;-fx-font-size:11px;-fx-padding:4 10;-fx-cursor:hand;"/>
                </HBox>

                <VBox spacing="4">
                    <Label text="Nombre del Curso" style="-fx-text-fill:rgba(255,255,255,0.6);-fx-font-size:11px;"/>
                    <TextField fx:id="txtNombreCurso" promptText="Ej: Programación III" styleClass="campo-texto"/>
                </VBox>
                <HBox spacing="10">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Sección" style="-fx-text-fill:rgba(255,255,255,0.6);-fx-font-size:11px;"/>
                        <TextField fx:id="txtSeccion" promptText="A" styleClass="campo-texto"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Día" style="-fx-text-fill:rgba(255,255,255,0.6);-fx-font-size:11px;"/>
                        <ComboBox fx:id="cmbDia" maxWidth="1.7976931348623157E308" promptText="Día"/>
                    </VBox>
                </HBox>
                <HBox spacing="10">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Hora Inicio" style="-fx-text-fill:rgba(255,255,255,0.6);-fx-font-size:11px;"/>
                        <TextField fx:id="txtHoraInicio" promptText="07:00" styleClass="campo-texto"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Hora Fin" style="-fx-text-fill:rgba(255,255,255,0.6);-fx-font-size:11px;"/>
                        <TextField fx:id="txtHoraFin" promptText="09:00" styleClass="campo-texto"/>
                    </VBox>
                </HBox>
                <VBox spacing="4">
                    <Label text="Catedrático" style="-fx-text-fill:rgba(255,255,255,0.6);-fx-font-size:11px;"/>
                    <ComboBox fx:id="cmbCatedratico" maxWidth="1.7976931348623157E308" promptText="Seleccionar..."/>
                </VBox>
                <VBox spacing="4">
                    <Label text="Salón" style="-fx-text-fill:rgba(255,255,255,0.6);-fx-font-size:11px;"/>
                    <ComboBox fx:id="cmbSalon" maxWidth="1.7976931348623157E308" promptText="Seleccionar..."/>
                </VBox>

                <Button fx:id="btnGuardarCurso" text="💾  Guardar Curso"
                        styleClass="btn-primario" maxWidth="1.7976931348623157E308"
                        onAction="#guardarCurso"/>
                <Label fx:id="lblMensajeCurso" text="" wrapText="true"
                       style="-fx-text-fill:#4fc3f7;-fx-font-size:11px;"/>
            </VBox>

            <!-- Inscripción de estudiantes -->
            <VBox spacing="10" VBox.vgrow="ALWAYS"
                  style="-fx-background-color:#111827;-fx-background-radius:12;-fx-padding:18;">
                <Label text="Estudiantes Inscritos"
                       style="-fx-text-fill:#e8edf5;-fx-font-size:13px;-fx-font-weight:bold;"/>
                <TableView fx:id="tablaInscritos" VBox.vgrow="ALWAYS" prefHeight="160">
                    <columns>
                        <TableColumn fx:id="colNombreEst" text="Nombre" prefWidth="170"/>
                        <TableColumn fx:id="colCarneEst"  text="Carné"  prefWidth="100"/>
                    </columns>
                    <placeholder>
                        <Label text="Selecciona un curso" style="-fx-text-fill:rgba(255,255,255,0.3);"/>
                    </placeholder>
                </TableView>
                <ComboBox fx:id="cmbEstudiante"
                          maxWidth="1.7976931348623157E308"
                          promptText="Agregar estudiante..."/>

                <HBox spacing="8" alignment="CENTER_RIGHT">
                    <Button text="+ Inscribir" onAction="#inscribirEstudiante"
                            style="-fx-background-color:rgba(37,99,235,0.85);-fx-background-radius:8;-fx-border-radius:8;-fx-text-fill:white;-fx-font-size:12px;-fx-font-weight:bold;-fx-padding:7 14;-fx-cursor:hand;-fx-min-width:90;"/>
                    <Button text="− Remover" onAction="#desinscribirEstudiante"
                            style="-fx-background-color:rgba(220,38,38,0.15);-fx-border-color:rgba(220,38,38,0.4);-fx-border-radius:8;-fx-background-radius:8;-fx-text-fill:#f87171;-fx-font-size:12px;-fx-font-weight:bold;-fx-padding:7 14;-fx-cursor:hand;-fx-min-width:90;"/>
                </HBox>
                <Label fx:id="lblMensajeInscripcion" text="" wrapText="true"
                       style="-fx-text-fill:#4fc3f7;-fx-font-size:11px;"/>
            </VBox>
        </VBox>
    </HBox>
</VBox>
