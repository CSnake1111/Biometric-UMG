<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="app.controladores.LoginController"
           prefWidth="900" prefHeight="600"
           style="-fx-background-color: #0a0f1e;"
           stylesheets="@../css/estilos.css">

    <!-- Fondo decorativo -->
    <VBox alignment="CENTER" spacing="0" style="-fx-background-color: #0a0f1e;">
        <Rectangle width="900" height="600" fill="#0a0f1e"/>
    </VBox>

    <HBox alignment="CENTER" spacing="0">

        <!-- Panel izquierdo: branding -->
        <VBox alignment="CENTER" spacing="20" prefWidth="420"
              style="-fx-background-color: #080d1a; -fx-padding: 60 50 60 50;">
            <ImageView fx:id="imgLogo" fitWidth="100" fitHeight="100" preserveRatio="true"/>
            <Label text="BiometricUMG"
                   style="-fx-text-fill: #4fc3f7; -fx-font-size: 28px; -fx-font-weight: bold;"/>
            <Label text="Sistema de Control Biométrico"
                   style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 13px;"/>
            <Label text="Universidad Mariano Gálvez"
                   style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 11px;"/>
            <Label text="Sede La Florida, Zona 19"
                   style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 11px;"/>

            <Separator style="-fx-opacity: 0.3;" maxWidth="200"/>

            <Label text="v3.0 — 2026"
                   style="-fx-text-fill: rgba(255,255,255,0.2); -fx-font-size: 10px;"/>
        </VBox>

        <!-- Panel derecho: formulario login -->
        <VBox alignment="CENTER" spacing="20" prefWidth="480"
              style="-fx-background-color: #0d1224; -fx-padding: 60 60 60 60;">

            <Label text="Iniciar Sesión"
                   style="-fx-text-fill: #e8edf5; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Label text="Ingresa tus credenciales para continuar"
                   style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 12px;"/>

            <VBox spacing="8" maxWidth="320" fillWidth="true">
                <Label text="Usuario o Carné"
                       style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 12px;"/>
                <TextField fx:id="txtUsuario" promptText="usuario@umg.edu.gt"
                           styleClass="campo-texto" maxWidth="1.7976931348623157E308"/>
            </VBox>

            <VBox spacing="8" maxWidth="320" fillWidth="true">
                <Label text="Contraseña"
                       style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 12px;"/>
                <PasswordField fx:id="txtPassword" promptText="••••••••"
                               styleClass="campo-texto" maxWidth="1.7976931348623157E308"/>
            </VBox>

            <!-- Panel error -->
            <VBox fx:id="panelError" visible="false" managed="false"
                  style="-fx-background-color: rgba(231,76,60,0.15); -fx-background-radius:8;
                         -fx-border-color: rgba(231,76,60,0.5); -fx-border-radius:8; -fx-padding: 10 16;"
                  maxWidth="320">
                <Label fx:id="lblError" text=""
                       style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;" wrapText="true"/>
            </VBox>

            <VBox spacing="10" maxWidth="320" fillWidth="true">
                <Button fx:id="btnLogin" text="INGRESAR AL SISTEMA"
                        styleClass="btn-primario" maxWidth="1.7976931348623157E308"
                        onAction="#onLogin"/>

                <HBox alignment="CENTER" spacing="8">
                    <ProgressIndicator fx:id="loadingIndicator" prefWidth="20" prefHeight="20"
                                       visible="false" managed="false"
                                       style="-fx-progress-color: #4fc3f7;"/>
                </HBox>

                <Button text="🎭  Iniciar con Reconocimiento Facial"
                        maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: rgba(79,195,247,0.1);
                               -fx-text-fill: #4fc3f7; -fx-border-color: rgba(79,195,247,0.3);
                               -fx-border-radius: 6; -fx-background-radius: 6;
                               -fx-cursor: hand; -fx-font-size: 12px; -fx-padding: 10;"
                        onAction="#toggleReconocimientoFacial"/>
            </VBox>

            <!-- Panel reconocimiento facial -->
            <VBox fx:id="panelFacial" visible="false" managed="false"
                  spacing="10" alignment="CENTER" maxWidth="320"
                  style="-fx-background-color: rgba(79,195,247,0.05);
                         -fx-border-color: rgba(79,195,247,0.2);
                         -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15;">
                <Label fx:id="lblCamaraUtilizar"
                       text="📷  Cámara a utilizar:"
                       style="-fx-text-fill: #8a9bbf; -fx-font-size: 11px;"/>
                <ComboBox fx:id="cmbCamara"
                          promptText="Seleccionando cámaras..."
                          maxWidth="1.7976931348623157E308"
                          style="-fx-background-color:#0d1829;-fx-text-fill:#e8edf5;
                 -fx-border-color:#1e2d47;-fx-border-radius:6;
                 -fx-background-radius:6;"/>
                <ImageView fx:id="imgCamaraLogin" fitWidth="280" fitHeight="180"
                           preserveRatio="true"
                           style="-fx-border-radius: 6; -fx-background-radius: 6;"/>
                <Label fx:id="lblEstadoFacial" text="Iniciando..."
                       style="-fx-text-fill: #4fc3f7; -fx-font-size: 12px;"/>
                <Button fx:id="btnFacial" text="Cancelar reconocimiento"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,100,100,0.8);
                               -fx-border-color: rgba(255,100,100,0.3); -fx-border-radius:6;
                               -fx-background-radius:6; -fx-cursor:hand; -fx-font-size:11px;"
                        onAction="#toggleReconocimientoFacial"/>
            </VBox>

        </VBox>
    </HBox>
</StackPane>
