<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="app.controladores.RestriccionesController"
      spacing="15" style="-fx-padding:20;-fx-background-color:#0d1224;">

    <Label text="🚫  Registro de Restricciones de Ingreso — Proceso 5"
           style="-fx-text-fill:#e74c3c;-fx-font-size:18px;-fx-font-weight:bold;"/>

    <HBox spacing="20" VBox.vgrow="ALWAYS">

        <!-- Panel izquierdo: agregar restricción -->
        <VBox spacing="14" minWidth="340" maxWidth="360"
              style="-fx-background-color:#111827;-fx-background-radius:12;-fx-padding:20;">
            <Label text="Agregar Restricción"
                   style="-fx-text-fill:#e8edf5;-fx-font-size:14px;-fx-font-weight:bold;"/>

            <VBox spacing="5">
                <Label text="Buscar Persona" style="-fx-text-fill:rgba(255,255,255,0.6);-fx-font-size:11px;"/>
                <TextField fx:id="txtBuscarPersona" promptText="Nombre o carné..."
                           styleClass="campo-texto"/>
            </VBox>

            <TableView fx:id="tablaPersonas" prefHeight="160">
                <columns>
                    <TableColumn fx:id="colNombreP" text="Nombre" prefWidth="150"/>
                    <TableColumn fx:id="colTipoP" text="Tipo" prefWidth="90"/>
                    <TableColumn fx:id="colCorreoP" text="Correo" prefWidth="180"/>
                </columns>
                <placeholder><Label text="Busca una persona" style="-fx-text-fill:rgba(255,255,255,0.3);"/></placeholder>
            </TableView>

            <Label fx:id="lblPersonaSeleccionada" text="Ninguna persona seleccionada"
                   style="-fx-text-fill:#f39c12;-fx-font-size:11px;" wrapText="true"/>

            <VBox spacing="5">
                <Label text="Motivo de Restricción *" style="-fx-text-fill:rgba(255,255,255,0.6);-fx-font-size:11px;"/>
                <TextArea fx:id="txtMotivo" promptText="Describe el motivo de la restricción..."
                          prefHeight="80" wrapText="true"
                          style="-fx-control-inner-background:#1a2035;-fx-text-fill:#e8edf5;
                                 -fx-background-color:transparent;-fx-border-color:rgba(255,255,255,0.15);
                                 -fx-border-radius:6;-fx-background-radius:6;-fx-font-size:12px;"/>
            </VBox>

            <HBox spacing="12">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Fecha Inicio" style="-fx-text-fill:rgba(255,255,255,0.6);-fx-font-size:11px;"/>
                    <DatePicker fx:id="dpFechaInicio" maxWidth="1.7976931348623157E308"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Fecha Fin" style="-fx-text-fill:rgba(255,255,255,0.6);-fx-font-size:11px;"/>
                    <DatePicker fx:id="dpFechaFin" maxWidth="1.7976931348623157E308"/>
                </VBox>
            </HBox>

            <Button fx:id="btnAgregar" text="🚫  Agregar Restricción"
                    maxWidth="1.7976931348623157E308"
                    style="-fx-background-color:#c0392b;-fx-text-fill:white;-fx-font-weight:bold;
                           -fx-background-radius:6;-fx-cursor:hand;-fx-padding:10;"
                    onAction="#agregarRestriccion"/>

            <Label fx:id="lblMensajeForm" text="" wrapText="true"
                   style="-fx-text-fill:#4fc3f7;-fx-font-size:11px;"/>
        </VBox>

        <!-- Panel derecho: lista de restricciones -->
        <VBox spacing="10" HBox.hgrow="ALWAYS"
              style="-fx-background-color:#111827;-fx-background-radius:12;-fx-padding:18;">
            <HBox alignment="CENTER_LEFT">
                <Label text="Restricciones Activas"
                       style="-fx-text-fill:#e8edf5;-fx-font-size:14px;-fx-font-weight:bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="🔄  Actualizar" styleClass="btn-secundario" onAction="#actualizarLista"/>
            </HBox>

            <TableView fx:id="tablaRestricciones" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colPersonaR" text="Persona" prefWidth="180"/>
                    <TableColumn fx:id="colMotivoR" text="Motivo" prefWidth="200"/>
                    <TableColumn fx:id="colInicioR" text="Inicio" prefWidth="100"/>
                    <TableColumn fx:id="colFinR" text="Fin" prefWidth="100"/>
                    <TableColumn fx:id="colEstadoR" text="Estado" prefWidth="90"/>
                    <TableColumn text="Acción" prefWidth="90"/>
                </columns>
                <placeholder>
                    <VBox alignment="CENTER" spacing="8">
                        <Label text="✅" style="-fx-font-size:28px;"/>
                        <Label text="No hay restricciones activas" style="-fx-text-fill:rgba(255,255,255,0.3);-fx-font-size:12px;"/>
                    </VBox>
                </placeholder>
            </TableView>
        </VBox>
    </HBox>
</VBox>
